[
  {
    "key": "content_specific_topic",
    "text": "In one sentence, what's your content about and who is it for?",
    "subtext": "e.g., '15-minute weeknight dinners for parents of picky eaters.'",
    "input_type": "text",
    "required": true,
    "maps_to": "market.target_customer"
  },
  {
    "key": "content_delivery_format",
    "text": "How will people get your teaching or content?",
    "input_type": "select",
    "options": [
      "Published content (videos, podcast, newsletter, blog)",
      "Online course or paid community",
      "Live sessions I deliver (one-on-one or small group)",
      "A mix of content and live sessions"
    ],
    "required": true,
    "maps_to": "idea.sales_channel"
  },
  {
    "key": "content_primary_monetisation",
    "text": "What's your primary way of making money from it?",
    "input_type": "select",
    "options": [
      "Ads",
      "Sponsorships",
      "Paid subscription",
      "Course sales",
      "Coaching / consulting",
      "Affiliate",
      "Merch"
    ],
    "required": true,
    "maps_to": "monetisation.primary_channel"
  },
  {
    "key": "content_secondary_monetisation",
    "text": "Any secondary revenue you're planning?",
    "input_type": "select",
    "options": [
      "None",
      "Ads",
      "Sponsorships",
      "Paid subscription",
      "Course sales",
      "Coaching / consulting",
      "Affiliate",
      "Merch"
    ],
    "required": false,
    "maps_to": "monetisation.secondary_channel"
  },
  {
    "key": "content_existing_content",
    "text": "How much have you published already?",
    "input_type": "select",
    "options": [
      "Nothing published",
      "A few pieces",
      "Regular cadence, small audience",
      "Regular cadence, growing"
    ],
    "required": true,
    "maps_to": "resource.existing_content",
    "show_if": {
      "key": "content_delivery_format",
      "in": [
        "Published content (videos, podcast, newsletter, blog)",
        "Online course or paid community",
        "A mix of content and live sessions"
      ]
    }
  },
  {
    "key": "content_audience_size",
    "text": "How big is your current audience?",
    "subtext": "Total across your primary channel.",
    "input_type": "select",
    "options": ["None yet", "Under 1k", "1k–10k", "10k–100k", "100k+"],
    "required": true,
    "maps_to": "resource.audience_size",
    "show_if": {
      "key": "content_delivery_format",
      "in": [
        "Published content (videos, podcast, newsletter, blog)",
        "Online course or paid community",
        "A mix of content and live sessions"
      ]
    }
  },
  {
    "key": "content_session_format",
    "text": "How will you run your sessions?",
    "input_type": "select",
    "options": ["Online (video calls)", "In person", "Both online and in person"],
    "required": true,
    "maps_to": "cost.fulfilment_model",
    "show_if": {
      "key": "content_delivery_format",
      "in": [
        "Live sessions I deliver (one-on-one or small group)",
        "A mix of content and live sessions"
      ]
    }
  },
  {
    "key": "content_session_pricing",
    "text": "How will you charge for sessions?",
    "input_type": "select",
    "options": ["Per single session", "Session packages", "Monthly subscription/retainer", "Not sure yet"],
    "required": true,
    "maps_to": "price.model",
    "show_if": {
      "key": "content_delivery_format",
      "in": [
        "Live sessions I deliver (one-on-one or small group)",
        "A mix of content and live sessions"
      ]
    }
  },
  {
    "key": "content_time_commitment",
    "text": "How much time will you put into this each week?",
    "input_type": "select",
    "options": ["Evenings/weekends only", "Part-time (~20 hrs)", "Full-time"],
    "required": true,
    "maps_to": "idea.time_commitment"
  }
]
