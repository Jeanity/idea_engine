NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
ANTHROPIC_API_KEY=sk-ant-...

# AI_PROVIDER: unset/"anthropic" = production (real API calls); "mock" = offline fixtures, $0, no network; "ollama" = local model via Ollama, no web search
AI_PROVIDER=anthropic
# Base URL of your local Ollama server (only used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
# Local model tag to use with Ollama (only used when AI_PROVIDER=ollama)
OLLAMA_MODEL=qwen2.5:14b

# Account email(s) that see admin controls (full-report test button, demo/live mode).
# Comma-separated for multiple admins; matching is case-insensitive.
ADMIN_EMAIL=you@example.com,also-you@example.com

# Transactional email (src/lib/mailer.ts). If ANY of the SMTP_* vars below are
# missing, sending becomes a no-op (logs a warning, never throws/blocks) — so
# these are safe to leave unset in local dev.
SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-mailbox-password
MAIL_FROM="Idea Engine <reports@hadidea.com>"
# Where admin-facing notifications (contact form, bug reports, new feedback) are sent.
ADMIN_NOTIFY_EMAIL=hello@hadidea.com

# Base URL used to build links inside emails (report pages, admin pages).
NEXT_PUBLIC_SITE_URL=https://hadidea.com
