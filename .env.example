NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
ANTHROPIC_API_KEY=sk-ant-...

# AI_PROVIDER: unset/"anthropic" = production (real API calls); "mock" = offline fixtures, $0, no network; "ollama" = local model via Ollama, no web search
AI_PROVIDER=anthropic
# Base URL of your local Ollama server (only used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
# Local model tag to use with Ollama (only used when AI_PROVIDER=ollama)
OLLAMA_MODEL=qwen2.5:14b

# Account email that sees admin test-mode controls (generate full report without payment)
ADMIN_EMAIL=you@example.com
